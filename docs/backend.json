
{
  "entities": {
    "TaxComplianceRecord": {
      "title": "Tax & Compliance Record",
      "description": "Digital audit trail for cross-border settlements with external gateway mapping.",
      "type": "object",
      "properties": {
        "txId": { "type": "string" },
        "externalTxId": { "type": "string", "description": "bKash or Xendit Transaction ID" },
        "provider": { "type": "string" },
        "amount": { "type": "number" },
        "mappedAmount": { "type": "number" },
        "currency": { "type": "string" },
        "userEmail": { "type": "string" },
        "complianceScore": { "type": "number" },
        "status": { "type": "string" },
        "timestamp": { "type": "number" },
        "metadata": { "type": "object" }
      }
    },
    "AppConnection": {
      "title": "Imperial App Connection",
      "description": "Registered application heartbeat and sync status.",
      "type": "object",
      "properties": {
        "appId": { "type": "string" },
        "name": { "type": "string" },
        "trustScore": { "type": "number" },
        "status": { "type": "string", "enum": ["SYNCHRONIZED", "DRIFT_DETECTED", "OFFLINE"] },
        "lastHeartbeat": { "type": "number" },
        "latency": { "type": "number" }
      }
    },
    "MerchantOnboarding": {
      "title": "Merchant Onboarding Request",
      "description": "Onboarding application and trust assessment.",
      "type": "object",
      "properties": {
        "businessName": { "type": "string" },
        "businessType": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "VERIFIED", "REJECTED", "UNDER_REVIEW"] },
        "trustScore": { "type": "number" },
        "gatewayApiKey": { "type": "string", "description": "Encrypted bKash/Xendit Key Storage" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/compliance_records/{logId}": {
      "schema": "TaxComplianceRecord",
      "description": "Audit-ready mapping logs"
    },
    "/merchant_onboarding_requests/{reqId}": {
      "schema": "MerchantOnboarding",
      "description": "Merchant gateway credentials"
    }
  }
}
