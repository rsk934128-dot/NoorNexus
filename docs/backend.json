
{
  "entities": {
    "ApiKey": {
      "title": "Sovereign API Key",
      "description": "Credentials for third-party TTP (Third Party Provider) access.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "clientSecret": { "type": "string" },
        "owner": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["ACTIVE", "REVOKED"] },
        "createdAt": { "type": "number" }
      },
      "required": ["clientId", "clientSecret", "owner", "status"]
    },
    "AppConnection": {
      "title": "Imperial App Connection",
      "description": "Registered application heartbeat and sync status.",
      "type": "object",
      "properties": {
        "appId": { "type": "string" },
        "name": { "type": "string" },
        "trustScore": { "type": "number" },
        "status": { "type": "string", "enum": ["SYNCHRONIZED", "DRIFT_DETECTED", "OFFLINE"] },
        "lastHeartbeat": { "type": "number" },
        "latency": { "type": "number" }
      }
    },
    "TaxComplianceRecord": {
      "title": "Tax & Compliance Record",
      "description": "Digital audit trail for cross-border settlements.",
      "type": "object",
      "properties": {
        "txId": { "type": "string" },
        "amount": { "type": "number" },
        "taxAmount": { "type": "number" },
        "complianceScore": { "type": "number" },
        "status": { "type": "string" },
        "region": { "type": "string" },
        "timestamp": { "type": "number" }
      }
    },
    "WebhookLog": {
      "title": "Webhook Event",
      "description": "Logs of incoming and outgoing Open Banking events.",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "type": { "type": "string" },
        "payload": { "type": "string" },
        "targetUrl": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "number" }
      }
    },
    "NodeStatus": {
      "title": "Node Status",
      "description": "Real-time status and metrics of a distributed ledger node.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "region": { "type": "string" },
        "status": { "type": "string", "enum": ["Operational", "Maintenance", "Degraded"] },
        "latency": { "type": "number" },
        "load": { "type": "number" },
        "successRate": { "type": "number" },
        "integrity": { "type": "string", "enum": ["Verified", "Untrusted"] },
        "lastSeen": { "type": "string", "format": "date-time" }
      }
    },
    "BorderLog": {
      "title": "HMAC_V4 Border Log",
      "description": "Incoming request logs at the digital border.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "number" },
        "signature": { "type": "string" },
        "origin": { "type": "string" },
        "path": { "type": "string" },
        "result": { "type": "string", "enum": ["ACCEPTED", "REJECTED", "WARNING"] },
        "reason": { "type": "string" },
        "riskScore": { "type": "number" }
      }
    },
    "TreasuryStatus": {
      "title": "Sovereign Treasury Overview",
      "description": "Multi-ledger balances and liquidity health.",
      "type": "object",
      "properties": {
        "totalVolume": { "type": "number" },
        "settlementQueue": { "type": "number" },
        "liquidityHealth": { "type": "number" },
        "dailyThroughput": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/app_connections/{connId}": {
      "schema": "AppConnection",
      "description": "Imperial SDK heartbeat registry"
    },
    "/api_keys/{keyId}": {
      "schema": "ApiKey",
      "description": "Gateway access credentials"
    },
    "/compliance_records/{logId}": {
      "schema": "TaxComplianceRecord",
      "description": "Audit-ready tax and compliance logs"
    },
    "/webhook_logs/{logId}": {
      "schema": "WebhookLog",
      "description": "Event synchronization logs"
    },
    "/nodes/{nodeId}": {
      "schema": "NodeStatus",
      "description": "Distributed node metrics"
    },
    "/border_logs/{logId}": {
      "schema": "BorderLog",
      "description": "Border entry monitoring"
    },
    "/treasury/global": {
      "schema": "TreasuryStatus",
      "description": "Global treasury metrics"
    }
  }
}
