
{
  "entities": {
    "ApiKey": {
      "title": "Sovereign API Key",
      "description": "Credentials for third-party TTP (Third Party Provider) access.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "clientSecret": { "type": "string" },
        "owner": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["ACTIVE", "REVOKED"] },
        "createdAt": { "type": "number" }
      },
      "required": ["clientId", "clientSecret", "owner", "status"]
    },
    "WebhookLog": {
      "title": "Webhook Event",
      "description": "Logs of incoming and outgoing Open Banking events.",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "type": { "type": "string" },
        "payload": { "type": "string" },
        "targetUrl": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "number" }
      }
    },
    "NodeStatus": {
      "title": "Node Status",
      "description": "Real-time status and metrics of a distributed ledger node.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "region": { "type": "string" },
        "status": { "type": "string", "enum": ["Operational", "Maintenance", "Degraded"] },
        "latency": { "type": "number" },
        "load": { "type": "number" },
        "successRate": { "type": "number" },
        "integrity": { "type": "string", "enum": ["Verified", "Untrusted"] },
        "lastSeen": { "type": "string", "format": "date-time" }
      }
    },
    "BorderLog": {
      "title": "HMAC_V4 Border Log",
      "description": "Incoming request logs at the digital border.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "number" },
        "signature": { "type": "string" },
        "origin": { "type": "string" },
        "path": { "type": "string" },
        "result": { "type": "string", "enum": ["ACCEPTED", "REJECTED", "WARNING"] },
        "reason": { "type": "string" },
        "riskScore": { "type": "number" }
      }
    },
    "TreasuryStatus": {
      "title": "Sovereign Treasury Overview",
      "description": "Multi-ledger balances and liquidity health.",
      "type": "object",
      "properties": {
        "totalVolume": { "type": "number" },
        "settlementQueue": { "type": "number" },
        "liquidityHealth": { "type": "number" },
        "dailyThroughput": { "type": "number" }
      }
    },
    "PaymentMethod": {
      "title": "Payment Method",
      "description": "Configuration for an ecosystem payment gateway.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "provider": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Deprecated", "Maintenance"] },
        "volume": { "type": "string" },
        "health": { "type": "string" },
        "timestamp": { "type": "number" }
      }
    },
    "P2CTransaction": {
      "title": "P2C Settlement",
      "description": "Corporate to Consumer disbursement log.",
      "type": "object",
      "properties": {
        "merchantId": { "type": "string" },
        "consumerId": { "type": "string" },
        "amount": { "type": "number" },
        "asset": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "number" },
        "hmacSignature": { "type": "string" }
      }
    },
    "SportsMatch": {
      "title": "Sovereign Match",
      "description": "Real-time football match data for Mission 400.",
      "type": "object",
      "properties": {
        "home": { "type": "string" },
        "away": { "type": "string" },
        "time": { "type": "string" },
        "score": { "type": "string" },
        "status": { "type": "string", "enum": ["LIVE", "UPCOMING", "FINISHED"] },
        "uplink": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "SportsServer": {
      "title": "Sports Relay Server",
      "description": "Relay node status for sports broadcasting.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" },
        "ping": { "type": "string" },
        "load": { "type": "string" }
      }
    },
    "ChatMessage": {
      "title": "Imperial Chat",
      "description": "Live community interaction messages.",
      "type": "object",
      "properties": {
        "user": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "number" }
      }
    },
    "SportsNews": {
      "title": "Tactical Sports News",
      "description": "Mission 400 related sports updates.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "severity": { "type": "string", "enum": ["INFO", "URGENT", "CRITICAL"] },
        "timestamp": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/api_keys/{keyId}": {
      "schema": "ApiKey",
      "description": "Gateway access credentials"
    },
    "/webhook_logs/{logId}": {
      "schema": "WebhookLog",
      "description": "Event synchronization logs"
    },
    "/nodes/{nodeId}": {
      "schema": "NodeStatus",
      "description": "Distributed node metrics"
    },
    "/border_logs/{logId}": {
      "schema": "BorderLog",
      "description": "Border entry monitoring"
    },
    "/treasury/global": {
      "schema": "TreasuryStatus",
      "description": "Global treasury metrics"
    },
    "/payment_methods/{methodId}": {
      "schema": "PaymentMethod",
      "description": "Configured payment gateways"
    },
    "/p2c_transactions/{txId}": {
      "schema": "P2CTransaction",
      "description": "Corporate settlement history"
    },
    "/sports_matches/{matchId}": {
      "schema": "SportsMatch",
      "description": "World Cup match feed"
    },
    "/sports_servers/{serverId}": {
      "schema": "SportsServer",
      "description": "Streaming relay server status"
    },
    "/sports_chat/{chatId}": {
      "schema": "ChatMessage",
      "description": "Live community chat"
    },
    "/sports_news/{newsId}": {
      "schema": "SportsNews",
      "description": "Tactical news feed"
    }
  }
}
