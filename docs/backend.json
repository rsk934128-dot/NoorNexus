
{
  "entities": {
    "Payment": {
      "title": "Sovereign Payment Record",
      "description": "Core payment entity with idempotency and state tracking.",
      "type": "object",
      "properties": {
        "paymentId": { "type": "string" },
        "provider": { "type": "string" },
        "externalTxId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["CREATED", "PENDING", "PROCESSING", "SUCCESS", "FAILED", "REFUNDED", "DISPUTED"] },
        "idempotencyKey": { "type": "string" },
        "userEmail": { "type": "string" },
        "riskScore": { "type": "number" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      }
    },
    "Settlement": {
      "title": "Treasury Settlement Record",
      "description": "Tracking when money actually moves from Gateway to Treasury.",
      "type": "object",
      "properties": {
        "settlementId": { "type": "string" },
        "paymentId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["PENDING", "SETTLED", "RECONCILED", "FAILED"] },
        "settledAt": { "type": "number" }
      }
    },
    "LedgerEntry": {
      "title": "Double-Entry Ledger",
      "description": "Immutable event chain for financial auditing.",
      "type": "object",
      "properties": {
        "entryId": { "type": "string" },
        "paymentId": { "type": "string" },
        "type": { "type": "string", "enum": ["DEBIT", "CREDIT"] },
        "amount": { "type": "number" },
        "asset": { "type": "string" },
        "timestamp": { "type": "number" }
      }
    },
    "AuditLog": {
      "title": "Operational Audit Log",
      "description": "Immutable record of system actions and security events.",
      "type": "object",
      "properties": {
        "logId": { "type": "string" },
        "action": { "type": "string" },
        "actor": { "type": "string" },
        "severity": { "type": "string", "enum": ["INFO", "WARNING", "CRITICAL"] },
        "metadata": { "type": "object" },
        "timestamp": { "type": "number" }
      }
    },
    "AppConnection": {
      "title": "Imperial App Connection",
      "description": "Registered application heartbeat and sync status.",
      "type": "object",
      "properties": {
        "appId": { "type": "string" },
        "name": { "type": "string" },
        "trustScore": { "type": "number" },
        "status": { "type": "string", "enum": ["SYNCHRONIZED", "DRIFT_DETECTED", "OFFLINE"] },
        "lastHeartbeat": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Source of truth for all transactions"
    },
    "/ledger/{entryId}": {
      "schema": "LedgerEntry",
      "description": "Immutable financial events"
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "Immutable operational history"
    },
    "/settlements/{settlementId}": {
      "schema": "Settlement",
      "description": "Gateway to Treasury reconciliation"
    }
  }
}
